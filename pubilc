
<!doctype html>
<html lang="zh-CN"><html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <title>图片转 Excel 粘贴工具</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 16px;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      color: #1f2328;
      background: #f6f8fa;
    }

    .app {
      max-width: 760px;
      margin: 0 auto;
    }

    h1 {
      margin: 0 0 14px;
      font-size: 22px;
      text-align: center;
    }

    .upload-box {
      display: block;
      width: 100%;
      padding: 22px 14px;
      border: 2px dashed #2f81f7;
      border-radius: 10px;
      background: #fff;
      text-align: center;
      cursor: pointer;
    }

    .upload-box input {
      display: none;
    }

    .status {
      margin: 10px 0;
      color: #57606a;
      font-size: 14px;
      text-align: center;
      min-height: 20px;
    }

    .preview {
      display: flex;
      gap: 10px;
      overflow-x: auto;
      min-height: 112px;
      padding: 10px;
      background: #fff;
      border-radius: 10px;
    }

    .item {
      flex: 0 0 auto;
      width: 100px;
    }

    .item img {
      width: 100px;
      height: 100px;
      object-fit: cover;
      border-radius: 6px;
      border: 1px solid #d0d7de;
      display: block;
    }

    .actions {
      display: flex;
      gap: 10px;
      margin-top: 12px;
    }

    button {
      flex: 1;
      border: 0;
      border-radius: 8px;
      height: 44px;
      color: #fff;
      font-size: 15px;
      background: #2da44e;
    }

    button:disabled {
      opacity: 0.55;
    }

    button.danger {
      background: #cf222e;
    }

    .manual-copy {
      display: none;
      margin-top: 12px;
      background: #fff8c5;
      border: 1px solid #d4a72c;
      border-radius: 8px;
      padding: 10px;
    }

    .manual-copy p {
      margin: 0 0 8px;
      font-size: 13px;
    }

    .manual-area {
      min-height: 66px;
      border: 1px dashed #d4a72c;
      border-radius: 6px;
      padding: 8px;
      background: #fff;
      overflow-x: auto;
      -webkit-user-select: text;
      user-select: text;
    }
  </style>
</head>
<body>
  <main class="app">
    <h1>图片转 Excel 粘贴工具</h1>

    <label for="fileInput" class="upload-box" id="uploadBox">
      <span>点击选择图片（可多选）</span>
      <input id="fileInput" type="file" accept="image/*" multiple>
    </label>

    <p id="statusText" class="status">未选择图片</p>
    <div id="previewBox" class="preview"></div>

    <div class="actions">
      <button id="copyBtn" disabled>复制到 Excel / WPS</button>
      <button id="clearBtn" class="danger">清空</button>
    </div>

    <section id="manualCopyWrap" class="manual-copy">
      <p>自动复制失败时，请长按下面区域并复制：</p>
      <div id="manualCopyArea" class="manual-area" contenteditable="true"></div>
    </section>
  </main>

  <script>
    const fileInput = document.getElementById("fileInput");
    const previewBox = document.getElementById("previewBox");
    const statusText = document.getElementById("statusText");
    const copyBtn = document.getElementById("copyBtn");
    const clearBtn = document.getElementById("clearBtn");
    const manualCopyWrap = document.getElementById("manualCopyWrap");
    const manualCopyArea = document.getElementById("manualCopyArea");

    const imageFiles = [];
    let objectUrls = [];

    function setStatus(text) {
      statusText.textContent = text;
    }

    function updateState() {
      copyBtn.disabled = imageFiles.length === 0;
      setStatus(imageFiles.length ? `已选择 ${imageFiles.length} 张图片` : "未选择图片");
    }

    function cleanupObjectUrls() {
      objectUrls.forEach((url) => URL.revokeObjectURL(url));
      objectUrls = [];
    }

    function renderPreview() {
      cleanupObjectUrls();
      previewBox.innerHTML = "";

      imageFiles.forEach((file) => {
        const url = URL.createObjectURL(file);
        objectUrls.push(url);
        const item = document.createElement("div");
        item.className = "item";
        const img = document.createElement("img");
        img.src = url;
        img.alt = "图片预览";
        item.appendChild(img);
        previewBox.appendChild(item);
      });

      updateState();
    }

    function addFiles(files) {
      files
        .filter((file) => file.type && file.type.startsWith("image/"))
        .forEach((file) => imageFiles.push(file));
      renderPreview();
    }

    async function loadImageSource(file) {
      try {
        return await createImageBitmap(file);
      } catch {
        return await new Promise((resolve, reject) => {
          const url = URL.createObjectURL(file);
          const img = new Image();
          img.onload = () => {
            URL.revokeObjectURL(url);
            resolve(img);
          };
          img.onerror = () => {
            URL.revokeObjectURL(url);
            reject(new Error("图片加载失败"));
          };
          img.src = url;
        });
      }
    }

    function disposeImageSource(src) {
      if (src && typeof src.close === "function") {
        src.close();
      }
    }

    async function compressFileToJpegDataUrl(file, maxEdge, jpegQuality) {
      const src = await loadImageSource(file);
      try {
        const w0 = src.width != null ? src.width : src.naturalWidth;
        const h0 = src.height != null ? src.height : src.naturalHeight;
        if (!w0 || !h0) {
          throw new Error("无法读取图片尺寸");
        }
        const scale = Math.min(1, maxEdge / Math.max(w0, h0));
        const cw = Math.max(1, Math.round(w0 * scale));
        const ch = Math.max(1, Math.round(h0 * scale));
        const canvas = document.createElement("canvas");
        canvas.width = cw;
        canvas.height = ch;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(src, 0, 0, cw, ch);
        return {
          dataUrl: canvas.toDataURL("image/jpeg", jpegQuality),
          width: cw,
          height: ch
        };
      } finally {
        disposeImageSource(src);
      }
    }

    async function buildTableHtml() {
      const n = imageFiles.length;
      const maxEdge = Math.max(48, Math.min(80, Math.floor(1500 / Math.max(1, n))));
      const jpegQuality = n > 12 ? 0.72 : 0.78;

      let html = "<table><tr>";
      for (const file of imageFiles) {
        const { dataUrl, width, height } = await compressFileToJpegDataUrl(
          file,
          maxEdge,
          jpegQuality
        );
        html += `<td><img src="${dataUrl}" width="${width}" height="${height}"></td>`;
      }
      html += "</tr></table>";
      return html;
    }

    function copyWithExecCommand(html) {
      const temp = document.createElement("div");
      temp.contentEditable = "true";
      temp.style.position = "fixed";
      temp.style.left = "-9999px";
      temp.innerHTML = html;
      document.body.appendChild(temp);

      const range = document.createRange();
      range.selectNodeContents(temp);
      const selection = window.getSelection();
      selection.removeAllRanges();
      selection.addRange(range);

      let ok = false;
      try {
        ok = document.execCommand("copy");
      } catch (error) {
        ok = false;
      }

      selection.removeAllRanges();
      document.body.removeChild(temp);
      return ok;
    }

    function showManualArea(html) {
      manualCopyArea.innerHTML = html;
      manualCopyWrap.style.display = "block";

      manualCopyArea.focus();
      const selection = window.getSelection();
      const range = document.createRange();
      range.selectNodeContents(manualCopyArea);
      selection.removeAllRanges();
      selection.addRange(range);
    }

    async function copyImages() {
      if (!imageFiles.length) {
        alert("请先选择图片");
        return;
      }

      copyBtn.disabled = true;
      copyBtn.textContent = "复制中...";      copyBtn.textContent = "复制中...";
      manualCopyWrap.style.display = "none";      manualCopyWrap.style.display = "none";
      manualCopyArea.innerHTML = "";      manualCopyArea.innerHTML = "";

      try {      try {
        const tableHtml = await buildTableHtml();        const tableHtml = await buildTableHtml();

        if (window.ClipboardItem && navigator.clipboard && navigator.clipboard.write) {        if (window.ClipboardItem && navigator.clipboard && navigator.clipboard.write) {
          await navigator.clipboard.write([          await navigator.clipboard.write([
            new ClipboardItem({            new ClipboardItem({
              "text/html": new Blob([tableHtml], { type: "text/html" }),              "text/html": new Blob([tableHtml], { type: "text/html" }),
              "text/plain": new Blob(["图片已复制"], { type: "text/plain" })              "text/plain": new Blob(["图片已复制"], { type: "text/plain" })
            })            })
          ]);          ]);
          alert("复制成功，可去 Excel / WPS 粘贴");          alert("复制成功，可去 Excel / WPS 粘贴");
          return;          return;
        }        }

        if (copyWithExecCommand(tableHtml)) {        if (copyWithExecCommand(tableHtml)) {
          alert("复制成功（兼容模式），可去 Excel / WPS 粘贴");          alert("复制成功（兼容模式），可去 Excel / WPS 粘贴");
          return;          return;
        }        }

        showManualArea(tableHtml);        showManualArea(tableHtml);
        alert("自动复制失败，请长按黄色区域手动复制");        alert("自动复制失败，请长按黄色区域手动复制");
      } catch (error) {      } catch (error) {
        try {        try {
          const html = await buildTableHtml();          const html = await buildTableHtml();
          if (copyWithExecCommand(html)) {          if (copyWithExecCommand(html)) {
            alert("复制成功（兼容模式），可去 Excel / WPS 粘贴");            alert("复制成功（兼容模式），可去 Excel / WPS 粘贴");
          } else {          } else {
            showManualArea(html);            showManualArea(html);
            alert("自动复制失败，请长按黄色区域手动复制");            alert("自动复制失败，请长按黄色区域手动复制");
          }          }
        } catch (fallbackError) {        } catch (fallbackError) {
          alert("复制失败：" + (fallbackError.message || error.message || "未知错误"));          alert("复制失败：" + (fallbackError.message || error.message || "未知错误"));
        }        }
      } finally {      } finally {
        copyBtn.textContent = "复制到 Excel / WPS";        copyBtn.textContent = "复制到 Excel / WPS";
        copyBtn.disabled = imageFiles.length === 0;        copyBtn.disabled = imageFiles.length === 0;
      }      }
    }    }

    function clearAll() {    function clearAll() {
      imageFiles.splice(0, imageFiles.length);      imageFiles.splice(0, imageFiles.length);
      fileInput.value = "";      fileInput.value = "";
      cleanupObjectUrls();      cleanupObjectUrls();
      previewBox.innerHTML = "";      previewBox.innerHTML = "";
      manualCopyWrap.style.display = "none";      manualCopyWrap.style.display = "none";
      manualCopyArea.innerHTML = "";      manualCopyArea.innerHTML = "";
      updateState();      updateState();
    }    }

    fileInput.addEventListener("change", (event) => {    fileInput.addEventListener("change", (event) => {
      const files = Array.from(event.target.files || []);      const files = Array.from(event.target.files || []);
      addFiles(files);      addFiles(files);
      fileInput.value = "";      fileInput.value = "";
    });    });

    copyBtn.addEventListener("click", copyImages);    copyBtn.addEventListener("click", copyImages);
    clearBtn.addEventListener("click", clearAll);    clearBtn.addEventListener("click", clearAll);

    updateState();    updateState();
  </script>  </script>
</body></body>
</html></html>
